{
  "name": "playwright",
  "version": "1.0.0",
  "description": "Consolidated Playwright project for web crawling and test generation",
  "private": true,
  "type": "module",
  "workspaces": [
    "crawler",
    "testgen"
  ],
  "scripts": {
    "build": "npm run build -w crawler && npm run build -w testgen",
    "crawler": "npm -w crawler",
    "crawler:dev": "npm run dev -w crawler",
    "crawler:build": "npm run build -w crawler",
    "crawler:start": "npm run start -w crawler",
    "testgen": "npm -w testgen",
    "testgen:build": "npm run build -w testgen",
    "testgen:generate": "npm run generate -w testgen"
  },
  "keywords": [
    "playwright",
    "crawler",
    "testgen"
  ],
  "author": "",
  "license": "ISC"
}
